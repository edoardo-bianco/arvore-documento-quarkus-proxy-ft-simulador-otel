{
  "description": "Baseline e checkpoints SonarQube para mudanças de código; documentação é isenta.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$(git rev-parse --show-toplevel)/.codex/hooks/sonar-session-start.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/sonar-session-start.ps1')\"",
            "timeout": 60,
            "statusMessage": "Preparando a regra de qualidade SonarQube"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$(git rev-parse --show-toplevel)/.codex/hooks/sonar-stop.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/sonar-stop.ps1')\"",
            "timeout": 30,
            "statusMessage": "Avaliando se a mudança exige checkpoint SonarQube"
          }
        ]
      }
    ]
  }
}
