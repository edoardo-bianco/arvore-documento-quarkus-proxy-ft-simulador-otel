                    type: array
                    items:
                      $ref: '#/components/schemas/v1.dossie-produto.ClienteDTO'
                  processo:
                    description: Processo originador do dossiê de produto.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.dossie-produto.ProcessoDTO'
                  fase_atual:
                    description: Fase atual do dossiê de produto.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.dossie-produto.ProcessoDTO1'
                  situacao_atual:
                    description: Situação atual em que se encontra o dossiê de produto.
                    type: object
