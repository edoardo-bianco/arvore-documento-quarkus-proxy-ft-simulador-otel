                      de produto
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.dossieproduto.ProdutoContratadoDTO'
        "400":
          description: Falha no processamento.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
