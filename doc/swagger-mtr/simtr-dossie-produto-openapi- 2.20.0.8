  /simtr-dossie-produto/v1/dossie-produto/cnpj/{cnpj}:
    get:
      tags:
      - Negócio - Dossiê Produto
      description: Consulta de dossiê de produto pelo cnpj.
      parameters:
      - name: cnpj
        in: path
        description: Cnpj do dossiê de produto a ser localizado
        required: true
        schema:
          type: string
      responses:
        "200":
          description: Dossiês localizados com sucesso.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar um Dossiê de Produto.
                required:
                - id
                - chave_correlacao_canal
                - canal_criacao
                - unidade_criacao
                - data_criacao
                - processo
                - fase_atual
                - situacao_atual
                - unidades_tratamento
                type: object
                properties:
                  id:
                    format: int64
                    description: Identificador do dossiê de produto.
                    type: integer
                  chave_correlacao_canal:
                    format: int64
                    description: Indica identificador único fornecido pelo canal para
                      a criação daquele dossiê
                    type: integer
                  instancia_jbpm:
                    format: int64
                    description: Identificador da instância do processo JBPM.
                    type: integer
                  numero_negocio:
                    format: int64
                    description: Identificador da instância de processo BPM no SINDA.
                    type: integer
                  canal_criacao:
                    description: Sigla do canal de de comunicação reesponsável pela
                      criação do dossiê de produto.
                    type: string
                  unidade_criacao:
                    format: int32
                    description: CGC de identificação da unidade de criação do dossiê
                      de produto.
                    type: integer
                  data_criacao:
                    description: Data/Hora de criação do dossiê de produto.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  clientes:
                    description: Lista de produtos contratados vinculados ao dossiê
                      de produto
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.dossie-produto.ClienteDTO'
                  processo:
                    description: Processo originador do dossiê de produto.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.dossie-produto.ProcessoDTO'
                  fase_atual:
                    description: Fase atual do dossiê de produto.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.dossie-produto.ProcessoDTO1'
                  situacao_atual:
                    description: Situação atual em que se encontra o dossiê de produto.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.dossie-produto.SituacaoDTO'
                  unidades_tratamento:
                    description: Lista contendo CGCs das unidades definidas para tratamento
                      neste momento para o dossiê de produto.
                    type: array
                    items:
                      format: int32
                      type: integer
                  produtos_contratados:
                    description: Lista de produtos contratados vinculados ao dossiê
                      de produto
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.dossieproduto.ProdutoContratadoDTO'
        "204":
