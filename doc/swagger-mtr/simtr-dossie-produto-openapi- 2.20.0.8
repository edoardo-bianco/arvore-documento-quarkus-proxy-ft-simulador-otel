      description: Objeto utilizado para representar URL de documentos com acesso
        para download.
      required:
      - url_storage
      - validade
      - quantidadeBytes
      type: object
      properties:
        url_storage:
          description: URL do endpoint do serviço de blob storage.
          type: string
        validade:
          description: Data/Hora de exipiração da URL.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        quantidadeBytes:
          format: int64
          description: Quantidade de bytes do documento.
          type: integer
          example: 0
