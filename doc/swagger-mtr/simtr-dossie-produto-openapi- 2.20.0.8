          - $ref: '#/components/schemas/v1.dossie-produto.ProcessoDTO1'
        produto:
          description: Produto vinculados ao campo do formulario respondido.
          type: object
          allOf:
          - $ref: '#/components/schemas/v1.dossieproduto.ProdutoContratadoDTO'
        garantia:
          description: Garantia da vinculaçao ao campo do formulario respondido.
          type: object
          allOf:
          - $ref: '#/components/schemas/v1.dossie-produto.TipoDocumentoDTO'
    v1.armazenamento.ContainerDTO:
      description: Objeto utilizado para representar um tokes SAS de um serviço de
        blob storage.
      required:
      - sas
      - validade
      - url_storage
      - tipo_token_sas
      type: object
      properties:
        sas:
          description: tokes SAS de um serviço de blob storage.
          type: string
        validade:
          description: Data/Hora de exipiração do token SAS.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        url_storage:
          description: URL  do endpoint do serviço de blob storage.
          type: string
        tipo_token_sas:
          description: Tipo do tokes SAS de um serviço de blob storage.
          type: string
          allOf:
          - $ref: '#/components/schemas/TipoTokenSas'
        nome:
          description: Nome do container.
          type: string
    v1.armazenamento.CotainerListaDTO:
      description: Objeto utilizado para representar o container.
      required:
      - nome
      - acesso
      - ultima_alteracao
      type: object
      properties:
        nome:
          description: Nome do container.
          type: string
        acesso:
          description: Nivel de acesso do conteiner.
          type: string
        ultima_alteracao:
          description: Data da ultima alteração do container.
          type: string
          allOf:
          - $ref: '#/components/schemas/LocalDateTime'
