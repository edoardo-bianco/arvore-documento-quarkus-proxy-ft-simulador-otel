components:
  schemas:
    AlterarAtributoDocumentoDTO:
      required:
      - chave
      - valor
      - objeto
      - opcoes_selecionadas
      - excluir
      type: object
      properties:
        chave:
          description: Chave do atributo.
          type: string
        valor:
          description: Valor do atributo do documento no caso de atributos objetivos.
            Se utilizado o elemento "opcoes_selecionadas" não deve ser informado
          type: string
          example: string
        objeto:
          description: array do atributo do documento
          type: string
        opcoes_selecionadas:
          description: Valor da opção selecionada no caso de atributos objetivos.
            Se utilizado o elemento "valor" não deve ser informado
          type: array
          items:
            type: string
        excluir:
          description: Valor para definir se a propriedade deve ser excluída.
          type: boolean
    AlterarPropriedadeDocumentoDTO:
      required:
      - chave
      - valor
      - objeto
      type: object
      properties:
        chave:
          description: Chave da propriedade.
          type: string
        valor:
          description: Valor da propriedade do documento.
          type: string
        objeto:
          description: array do atributo do documento
          type: string
        excluir:
          description: Valor para definir se a propriedade deve ser excluída.
          type: boolean
    Calendar:
      type: object
      properties:
        fields:
          type: array
          items:
            format: int32
            type: integer
        isSet:
          type: array
          items:
            type: boolean
        time:
          format: int64
          type: integer
        isTimeSet:
          type: boolean
        areFieldsSet:
          type: boolean
        lenient:
          type: boolean
        zone:
          $ref: '#/components/schemas/TimeZone'
        firstDayOfWeek:
          format: int32
          type: integer
        minimalDaysInFirstWeek:
          format: int32
          type: integer
        nextStamp:
          format: int32
          type: integer
        serialVersionOnStream:
          format: int32
          type: integer
        timeInMillis:
          format: int64
          type: integer
        setStateFields:
          format: int32
          type: integer
        fieldsComputed:
          format: int32
          type: integer
        fieldsNormalized:
          format: int32
          type: integer
        partiallyNormalized:
          type: boolean
        fullyNormalized:
          type: boolean
        calendarType:
          type: string
        timeZone:
          $ref: '#/components/schemas/TimeZone'
        zoneShared:
          type: boolean
        weekDateSupported:
          type: boolean
        weekYear:
          format: int32
          type: integer
        weeksInWeekYear:
          format: int32
          type: integer
        weekCountData:
          $ref: '#/components/schemas/Locale'
    CodErroDeadLetterQueueReqBaseDTO:
      required:
      - codigo_erro
      type: object
      properties:
        codigo_erro:
          description: Código de erro da mensagem da fila Dead Letter a ser reprocessada.
          type: string
          example: MTRTMP0018
    CodigoRejeicaoEnum:
      enum:
      - DOC001
      - DOC002
      - DOC003
      - DOC004
      - DOC005
      - DOC006
      - FMT001
      - TIP001
      - TIP002
      - TIP003
      - NEG001
      - NEG002
      - NEG003
      - ARM001
      - IA001
      - IA002
      - IA003
      - IA004
      - IA005
      - IA006
      type: string
    DadosClienteDTO:
      type: object
      properties:
        cpf:
          description: 'CPF do cliente. '
          type: string
        cnpj:
          description: 'CNPJ do cliente. '
          type: string
    DeadLetterQueueReqDTO:
      required:
      - fila
      type: object
      properties:
        fila:
          description: Identificador da Fila de Dead Letter.
          type: string
          example: OUTSOURCING_ENVIO_FORNECEDOR_PROCESSOR
        codigos_erros:
          description: Lista de códigos de erros de mensagens da fila Dead Letter
            a serem reprocessadas.
          type: array
          items:
            $ref: '#/components/schemas/CodErroDeadLetterQueueReqBaseDTO'
    DestinoDocumentoDTO:
      type: object
      properties:
        localGravacao:
          $ref: '#/components/schemas/SiecmLocalGravacaoEnum'
        idDestino:
          type: string
        subPasta:
          type: string
      xml:
        name: DestinoDocumento
    ECMAtributosDocumentoDTO:
      type: object
      properties:
        classe:
          type: string
        gerarThumbnail:
          type: boolean
        tipo:
          type: string
        mimeType:
          type: string
        nome:
          type: string
        campo:
          type: array
          items:
            $ref: '#/components/schemas/v1.siecm.AtributosDTO1'
          xml:
            name: campo
            wrapped: true
      xml:
        name: atributos
    ECMDocumentoDTO:
      type: object
      properties:
        atributos:
          $ref: '#/components/schemas/ECMAtributosDocumentoDTO'
        binario:
          type: string
      xml:
        name: Documento
    ErrorMessage:
      type: object
      properties:
        mensagem:
          description: Mensagem de identificação do problema.
          type: string
    JanelaTemporalExtracaoEnum:
      enum:
      - M0
      - M30
      - M60
      type: string
    LocalDateTime:
      format: date-time
      type: string
      example: 2022-03-10T12:15:50
    Locale:
      type: object
      properties:
        language:
          type: string
        script:
          type: string
        country:
          type: string
        variant:
          type: string
        extensionKeys:
          uniqueItems: true
          type: array
          items:
            format: byte
            type: string
        unicodeLocaleAttributes:
          uniqueItems: true
          type: array
          items:
            type: string
        unicodeLocaleKeys:
          uniqueItems: true
          type: array
          items:
            type: string
        iSO3Language:
          type: string
        iSO3Country:
          type: string
        displayLanguage:
          type: string
        displayScript:
          type: string
        displayCountry:
          type: string
        displayVariant:
          type: string
        displayName:
          type: string
    OpcaoSelecionadaDTO:
      required:
      - valor
      - label
      type: object
      properties:
        valor:
          description: Valor do item selecionado.
          type: string
        label:
          description: Nome do campo selecionado.
          type: string
    RetornoErroDTO:
      description: Objeto utilizado para representar falhas nas requisições e devolver
        a indicação do problema para o usuário.
      type: object
      properties:
        codigo_http:
          format: int32
          description: Codigo HTTP definido para identificar o tipo de problema apresentado.
