          description: "Indica o tipo de componente a ser utilizado na montagem do\
            \ formulario para apresentação do campo.Ex: INPUT, RADIO, CHECK, etc."
          type: string
          allOf:
          - $ref: '#/components/schemas/TipoCampoEnum'
