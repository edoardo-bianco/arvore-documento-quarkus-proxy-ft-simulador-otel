                  no envio de inclusão sob a ótica dos cadastros.
                required:
                - nome_atributo_negocial
                - nome_atributo_documento
                - indicador_obrigatorio
                - ativo
                - indicador_calculo_data_validade
                - indicador_identificador_pessoa
                - indicador_presente_documento
                - orientacao_preenchimento
                - ordem_apresentacao
                - indicador_estrategia_partilha
                - indicador_calculo_guarda_permanente
                type: object
                properties:
                  nome_atributo_negocial:
                    description: Atributo utilizado para armazenar o nome do atributo
                      identificado pelo negocio. Esse valor armazena o nome utilizado
                      no dia a dia e que pode ser apresentado como algum label no
                      sistema quando necessario.
                    type: string
                  nome_atributo_documento:
                    description: Atributo utilizado para armazenar o nome do atributo
                      identificado pela integração com outros sistemas
                    type: string
                  nome_atributo_retorno:
                    description: Atributo utilizado para armazenar o nome do atributo
                      retornado pela rotina/serviço de extração de dados do documento.
                      Esse valor armazena o nome utilizado no campo de retorno da
                      informação
                    type: string
                  tipo_campo:
                    description: Atributo utilizado para indicar o tipo de campo que
                      deverá ser utilizado pela interface para os casos de captura
                      da informação quando inserida de forma manual
                    type: string
                  indicador_obrigatorio:
                    description: Atributo utilizado para indicar se esta informação
                      é de captura obrigatorio para o tipo de documento associado
                    type: boolean
                  ativo:
                    description: Atributo utilizado para definir se o atributo deve
                      ser procurado para captura no objeto de retorno dos dados extaidos
                      do documento.
                    type: boolean
                  nome_atributo_siecm:
                    description: Atributo utilizado para definir o nome do atributo
                      no SIECM. Caso seja enviado uma string vazia ("") que o campo
                      será definido como nulo.
                    type: string
                  tipo_atributo_siecm:
                    description: Atributo utilizado para indicar qual o tipo de dado
                      definido junto a classe SIECM.
                    type: string
                    allOf:
                    - $ref: '#/components/schemas/TipoAtributoEnum'
                  indicador_obrigatorio_siecm:
                    description: Atributo utilizado para indicar se esta informação
                      junto ao SIECM tem cunho obrigatorio.
                    type: boolean
                  nome_atributo_sicli:
                    description: Atributo utilizado para definir o nome do atributo
                      utilizado na atualização de dados do SICLI. Esse atributo deve
                      ser utilizado em conjunto com o atributo nome_objeto_sicli e
                      tipo_atributo_sicli que determina o agrupamento do atributo
                      a ser enviado na mensagem de atualização. Esse campo determina
                      o comportamento dos atributos nome_objeto_sicli e tipo_atributo_sicli
                      e caso informado o tipo_atributo_sicli se torna obrigatório.
                      Caso seja enviado uma string vazia ("") o campo será definido
                      como nulo e os campos relacionados também serão anulados.
                    type: string
                  nome_objeto_sicli:
                    description: Atributo utilizado para definir o objeto que agrupa
                      o atributo utilizado na atualização de dados do SICLI. Esse
                      atributo deve ser utilizado em conjunto com o atributo nome_atributo_sicli
                      e tipo_sicli que determina o agrupamento do atributo a ser enviado
                      na mensagem de atualização
                    type: string
                  tipo_atributo_sicli:
                    description: Atributo utilizado para indicar como (tipo de dado)
                      este registro deverá ser definido para envio ao SICLI na rotina
                      de atualização de dados.
                    type: string
                    allOf:
                    - $ref: '#/components/schemas/TipoAtributoEnum'
                  nome_sicod:
                    description: Atributo utilizado para definir o nome do atributo
                      a ser referencia na rotina de comunicação com o SICOD. Caso
                      seja enviado uma string vazia ("") que o campo será definido
                      como nulo.
                    type: string
                  tipo_atributo_sicod:
                    description: Atributo utilizado para indicar como (tipo de dado)
                      este registro deverá ser definido para envio ao SICOD na rotina
                      de conferencia documental do serviço do Dossiê Digital.
                    type: string
                    allOf:
                    - $ref: '#/components/schemas/TipoAtributoEnum'
                  indicador_campo_comparacao_receita:
                    description: Atributo utilizado para indicar qual campo de retorno
                      o SICPF deve ser utilizado para uma possivel comparação. Este
                      campo deve ser enviado mesmo não havendo modificação ou o mesmo
                      será anulado e anulará o atributo modo_comparacao_sicpf.
                    type: string
                    allOf:
                    - $ref: '#/components/schemas/SICPFCampoEnum'
                  indicador_modo_comparacao_receita:
                    description: "Atributo utilizado para indicar a forma de comparaç\
                      ão com o campo de retorno o SICPF deve ser utilizado para uma\
                      \ possivel comparação sendo que [E] indica que nome_dccumento\
                      \ deve ter o valor EXATO (igual) ao valor retornado no SICPF\
                      \ e o [P] indica que o valor deve estar contido na informaçã\
                      o retornada."
                    type: string
                    allOf:
                    - $ref: '#/components/schemas/SICPFModoEnum'
                  indicador_calculo_data_validade:
                    description: Atrinuto utilizado para indicar se o atributo extraido
                      do documento deve ser utilizado no calculo da data de validade
                      baseado nas regras do tipo de documento quanto a <validade autocontida>
                      e o <prazo de validade em dias>. Para este atributo deverá ter
                      apenas um regsitro marcado como true para o mesmo tipo de documento
                    type: boolean
                  indicador_identificador_pessoa:
                    description: Atributo utilizado para indicar se o atributo extraido
                      do documento deve ser utilizado como identificador de CPF/CNPJ
                      para associação do documento a um determinado dossiê de cliente
                    type: boolean
                  valor_padrao:
                    description: Atributo utilizado para manter opcionalmente um valor
                      padrão a ser utilizado no envio das informação para as integrações
                      quando não informado ou não capturado no documento.
                    type: string
                  indicador_presente_documento:
                    description: Atributo utilizado para indicar se a informação pode
                      ser encontrada no documento ou trata-se de um metadado necessario
                      para disponibilização da informação em algum sistema de integração.
                    type: boolean
                  orientacao_preenchimento:
                    description: Atributo utilizado para armazenar uma orientação
                      de preenchimento do campo a ser exibida nos formulários dinâmicos
                      apresentados ao operador que realiza extração de dados do documento.
                    type: string
                  grupo_atributo:
                    format: int32
                    description: "Indica o grupo ao qual o atributo faz parte. Caso\
                      \ este atributo faça parte de um grupo, todos os demais atributos\
                      \ do grupo deverão ser informados, caso ao menos um deles seja\
                      \ informado."
                    type: integer
                  ordem_apresentacao:
                    format: int32
                    description: Indica a sequencia de apresentação deste campo perante
                      o formulario.
                    type: integer
                  expressao_interface:
                    description: Determina uma expressão a ser utilizada pela interface
                      para definir a condição para o campo ser apresentado ou ocultado
                      no formulario.
                    type: string
                  indicador_modo_partilha:
                    description: "Atributo utilizado para indicar a forma de partilha\
                      \ da informação de um atributo quando comparado com o campo\
                      \ do SICLI que representa o nome da mãe indicando qual parte\
                      \ da informação deve ser enviada para outro atributo, sendo\
                      \ [S] para a SOBRA , ou seja tudo al´m do que foi localizado\
                      \ [L] para enviar ao novo campo o valor localizado"
                    type: string
                    allOf:
                    - $ref: '#/components/schemas/ModoPartilhaEnum'
                  identificador_atributo_partilha:
                    format: int32
                    description: Representa a relação com o atributo que deve ser
                      utilizado na partilha da informação quando comparado ao nome
                      da mãe do SICPF na forma indicada no atributo modo_partilha.
                      Para remover o vinculo existente deve ser enviado o valor -1.
                    type: integer
                  indicador_estrategia_partilha:
                    description: "Atributo utilizado para indicar como a partilha\
                      \ do campo deverá ser feita, quando for o caso. Ex: RECEITA_MAE\
                      \ signfica que a informalção do campo deve ser analisada baseado\
                      \ no nome da mãe obtido junto ao cadastro da receita federal."
                    type: string
                    allOf:
                    - $ref: '#/components/schemas/EstrategiaPartilhaEnum'
                  percentual_alteracao_permitido:
                    format: int32
                    description: "Atributo que representa o percentual adicional de\
                      \ alteração permitido sobre o valor recebido do OCR, no formato\
                      \ inteiro. Para definir o atributo como nulo deve ser enviado\
                      \ o valor -1."
                    type: integer
                  tamanho_maximo:
                    format: int32
                    description: Indica o numero de caracteres máximo utilizados em
                      campos de texto.
                    type: integer
                  objeto_documento:
                    description: Atributo utilizado para definir o objeto documento
                      vinculado ao atributo.
                    type: string
                  objeto_documento_label:
                    description: Atributo utilizado para definir o nome do objeto
                      documento vinculado ao atributo.
                    type: string
                  indicador_calculo_guarda_permanente:
                    description: "Atributo utilizado para indicar se o atributo é\
                      \ referência para o cálculo do prazo de guarda permanente do\
                      \ documento. Caso true, o prazo de guarda permanente começa\
                      \ a contar a partir da data definida neste atributo."
                    type: boolean
                  tamanho_apresentacao:
                    format: int32
                    description: "Indica o tamanho do campo do atributo para exibiç\
                      ão na interface. O tamanho segue o sistema de grid do Bootstrap\
                      \ (1 a 12), sendo 12 um campo que ocupa a tela (ou Modal) de\
                      \ ponta a ponta."
                    type: integer
                  tamanho_minimo:
                    format: int32
                    description: Indica o numero de caracteres mínimos utilizados
                      em campos de texto.
                    type: integer
                  placeholder:
                    description: Atributo utilizado para definir o placeholder utilizado
                      no atributo.
                    type: string
