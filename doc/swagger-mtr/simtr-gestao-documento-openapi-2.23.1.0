---
openapi: 3.0.3
info:
  title: SIMTR-gestao-documento
  description: "API de gestão dos documentos do SIMTR \n- Nível de Confidencialidade:\
    \ Nível II\r\n - Informações confidenciais / restritas\r\n- Timeout no API Manager:\
    \ 100 a 300 milissegundos (padrão)\r\n- Rate Limit no API Manager: Não definido\r\
    \n- Rate Limit no Backend:\tNão\tdefinido\r\n- Equipe de Desenvolvimento Responsá\
    vel:\tSUDEB02\t-\tComunidade\tde\tClientes\r\n- Equipe Gestora Negocial (Dono\
    \ do Produto):\tGEBAN\r\n- Nº do RTC de Validação do Swagger: "
  contact:
    name: "SUDEB02 - CRM, Cadastro"
    url: ""
    email: sudeb02@caixa.gov.br
  license:
    name: CAIXA
    url: https://www.caixa.gov.br
  version: 2.23.1.0
tags:
- name: gestao-documento
  description: API de gestão dos documentos do SIMTR.
- name: Negócio - Documento
  description: API de Apoio ao Negócio de Documento do SIMTR
- name: Negócio - Storage
  description: API de Apoio à Gestão de Armazenamento de documentos do SIMTR no Azure
    Blob Storage
paths:
  /simtr-gestao-documento/v1/documento:
    post:
      tags:
      - Negócio - Documento
      description: " Inclui um documento no sistema, opcionalmente vinculando-a um\
        \ Dossiê de Cliente. O documento deve estar previamente armazenado no Storage\
        \ ou no Ged."
      parameters:
      - name: cnpj
        in: query
        description: "CNPJ do cliente Pessoa Jurídica, ao qual devem ser vinculados\
          \ os documentos."
        required: false
        schema:
          type: string
      - name: cpf
        in: query
        description: "CPF do cliente Pessoa Física, ao qual devem ser vinculados os\
          \ documentos."
        required: false
        schema:
          type: string
      - name: id-cliente
        in: query
        description: "Id do Cliente previamente cadastrado no sistema, ao qual devem\
          \ ser vinculados os documentos."
        required: false
        schema:
          format: int64
          type: integer
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/v1.documento.DocumentoInclusaoDTO'
      responses:
        "201":
          description: Recurso criado com sucesso.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar a inclusão de um Documento.
                required:
                - id
                type: object
                properties:
                  id:
                    format: int64
                    description: 'Identificador único do registro de documento. '
                    type: integer
        "400":
          description: Falha nas validações da requisição.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "401":
          description: Usuário ou canal não autenticado.
        "403":
          description: Usuário ou canal não autorizado a utilizar o serviço.
        "404":
          description: Recurso não localizado para os parâmetros informados.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "409":
          description: A requisição não pode ser processada devido a um conflito.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "500":
          description: Falha não mapeada. Entre em contato com a equipe de desenvolvimento
            do SIMTR encaminhando o log recebido.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "503":
          description: Serviço de terceiros indisponível no momento.
      security:
      - apikey: []
  /simtr-gestao-documento/v1/documento/consulta:
    post:
      tags:
      - Negócio - Documento
      description: "Consulta de um documento, podendo ser utilizados parâmetros para\
        \ incrementar o retorno com as informações específicas necessárias. O retorno\
        \ da consulta é paginado e ordenado, essas informações devem ser informadas\
        \ no path da solicitação pelos atributos: \"pagina\" e \"ordem\"."
      parameters:
      - name: ordem
        in: query
        description: "São oferecidos três opções de ordenação: \"data-captura-asc\"\
          , \"data-captura-desc\" e \"ultima-alteracao\". Quando não informado a ordenaç\
          ão na solicitação o sistema não realiza uma ordenação dos resultados."
        required: false
        schema:
          type: string
      - name: pagina
        in: query
        description: "Quando não informado a página na solicitação o sistema apresenta\
          \ o total de páginas, o total de registros e são listados o 50 primeiros\
          \ documentos(\"pagina\":1) conforme o tipo de ordenação informado na solicitaç\
          ão, para consultar outras páginas, basta informar no atributo \"pagina\"\
          \ o número da página que deseja consultar e enviar a solicitação novamente."
        required: false
        schema:
          format: int32
          default: "1"
          type: integer
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/v1.documento.paginacao.DocumentoConsultaPropriedadeDTO'
      responses:
        "200":
          description: Recurso criado/ alterado/ localizado ou excluído com sucesso.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar o resultado de um Documento.
                required:
                - pagina
                - registro_pagina
                - total_paginas
                - total_registros_encontrados
                - retorno_consulta
                type: object
                properties:
                  pagina:
                    format: int64
                    description: Pagina.
                    type: integer
                  registro_pagina:
                    format: int32
                    description: Registro da Pagina.
                    type: integer
                  total_paginas:
                    format: int64
                    description: Quantitativo total de paginas.
                    type: integer
                  total_registros_encontrados:
                    format: int64
                    description: Quantitativo total de registros encontrados.
                    type: integer
                  retorno_consulta:
                    description: Objeto com o resultado paginado dos documentos solicitados.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ResultadoDocumentoDTO1'
        "400":
          description: Falha nas validações da requisição.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "401":
          description: Usuário ou canal não autenticado.
        "403":
          description: Usuário ou canal não autorizado a utilizar o serviço.
        "404":
          description: Recurso não localizado para os parâmetros informados.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "409":
          description: A requisição não pode ser processada devido a um conflito.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "500":
          description: Falha não mapeada. Entre em contato com a equipe de desenvolvimento
            do SIMTR encaminhando o log recebido.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "503":
          description: Serviço de terceiros indisponível no momento.
      deprecated: true
      security:
      - apikey: []
  /simtr-gestao-documento/v1/documento/minuta:
    post:
      tags:
      - Negócio - Documento
      description: "Gera um relatório com os parâmetros, retornando no formato base64."
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/v1.documento.GerarMinutaDTO'
      responses:
        "200":
          description: Geração de minuta efetuada com sucesso.
          content:
            application/json:
              schema:
                description: Objeto utilizado para retornar a minuta gerada em base64.
                required:
                - binario
                type: object
                properties:
                  binario:
                    description: Minuta gerada em base64.
                    type: string
        "400":
          description: Falha no processamento.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "404":
          description: Documento não localizado com o Id informado.
        "500":
          description: Falha não mapeada ao processar a requisição.
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - apikey: []
  /simtr-gestao-documento/v1/documento/{id}:
    get:
      tags:
      - Negócio - Documento
      description: "Consulta de um documento, podendo ser utilizados parâmetros para\
        \ incrementar o retorno com as informações específicas necessárias."
      parameters:
      - name: id
        in: path
        description: Identificador do documento na base de dados do SIMTR.
        required: true
        schema:
          format: int64
          type: integer
      - name: inclui-armazenamento
        in: query
        description: Indica se deve ser incluído no retorno o historico de armazenamento
          do documento.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-assinaturas
        in: query
        description: Indica se deve ser incluído no retorno as assinaturas digitais
          do documento.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-atributos
        in: query
        description: ' Indica se deve ser incluído no retorno os atributos extraídos
          do documento..'
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-binario
        in: query
        description: Indica se deve ser incluído no retorno o base64 do documento
          obtido no GED. Por padrão o canal consumidor do serviço deve buscar o base64
          do documento diretamente no GED através do identificador obtido neste serviço
          do SIMTR.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-conformidade
        in: query
        description: "Indica se deve ser incluído no retorno um resumo das verificaç\
          ões de conformidade realizadas para o documento, sejam elas realizadas pela\
          \ área de operações internas da Caixa ou por fornecedor externo."
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-outsourcing
        in: query
        description: Indica se deve ser incluído no retorno os serviços de outsourcing
          realizados para o documento.
        required: false
        schema:
          default: "false"
          type: boolean
      responses:
        "200":
          description: Documento localizado com sucesso.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar o resultado de um Documento.
                required:
                - id
                - tipo_documento
                - situacao_documento
                - canal
                - codigo_ged
                - data_hora_captura
                - matricula_captura
                - data_hora_validade
                - binario
                - outsourcing
                - atributos
                - assinaturas_digitais
                - conformidade
                - armazenamento
                type: object
                properties:
                  id:
                    format: int64
                    description: 'Identificador único do registro de documento. '
                    type: integer
                  tipo_documento:
                    description: Tipo do documento categorizado.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.documento.TipoDocumentoDTO'
                  situacao_documento:
                    description: Situação do documento.
                    type: string
                  canal:
                    description: Canal de captura do documento.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.documento.CanalDTO1'
                  codigo_ged:
                    description: Identificador do documento perante a solução de GED.
                    type: string
                  data_hora_captura:
                    description: Data/Hora de captura do documento.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  matricula_captura:
                    description: Matricula do usuário responsável pela captura do
                      documento.
                    type: string
                    example: c999999
                  data_hora_validade:
                    description: Data/Hora da validade do documento.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  data_hora_validacao_assinatura:
                    description: Data/Hora da validação de assinatura digital.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  binario:
                    description: Identificador do documento perante a solução de GED.
                    type: string
                  mime_type:
                    type: string
                    xml:
                      name: mime_type
                  outsourcing:
                    description: Objeto com o resultado dos serviços de outsourcing..
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.OutSourcingDTO2'
                  atributos:
                    description: Lista de atributos extraidos do documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.AtributoDTO1'
                  assinaturas_digitais:
                    description: Lista de assinaturas digitais vinculadas ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.AssinaturaDigitalDTO2'
                  conformidade:
                    description: Lista de conformidades do documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ConformidadeDTO1'
                  armazenamento:
                    description: Lista de armazenamento vinculado ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ArmazenamentoDTO'
        "400":
          description: Falha no processamento.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "404":
          description: Documento não localizado com o Id informado.
        "500":
          description: Falha não mapeada ao processar a requisição.
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      deprecated: true
      security:
      - apikey: []
    patch:
      tags:
      - Negócio - Documento
      description: ' Atualiza atributos e propriedades.'
      parameters:
      - name: id
        in: path
        description: Identificador do documento na base de dados do SIMTR.
        required: true
        schema:
          format: int64
          type: integer
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/v1.documento.AtualizarAtributoDocumentoDTO'
      responses:
        "200":
