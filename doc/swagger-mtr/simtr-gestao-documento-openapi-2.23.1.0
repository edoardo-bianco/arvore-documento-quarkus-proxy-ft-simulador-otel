        solicitacao_tratamento_imagem:
          description: Indice de solititação de tratamento de imagem documental.
          type: boolean
        solicitacao_extracao:
          description: Indice de solititação da extração documental.
          type: boolean
        solicitacao_validacao_negocial:
          description: Indice de solititação de validação negocial documental.
          type: boolean
        solicitacao_classificacao:
          description: Indice de solititação de classificação documental.
          type: boolean
        solicitacao_avaliacao_cadastral:
          description: Indice de solititação de avaliação cadastral documental.
          type: boolean
        solicitacao_avaliacao_autenticidade:
          description: Indice de solititação da avaliação de autenticidade documental.
