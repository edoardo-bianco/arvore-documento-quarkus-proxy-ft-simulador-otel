          format: int32
          description: Campo de controle das versões do registro.
          type: integer
        nome_etapa:
          description: Nome da Etapa.
          type: string
        observacao:
          description: Informações adicionais sobre a Etapa.
          type: string
        identificador_negocial:
          format: int64
          description: Identificador Negocial da Etapa.
          type: integer
        ordem:
          format: int64
          description: Ordem da etapa no fluxo do documento
          type: integer
        nome_fila:
          description: Nome da fila padrão da Etapa.
          type: string
        data_hora_alteracao:
          description: Data/Hora da última Alteração do cadastro da etapa.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
    v1.documento.GerarMinutaDTO:
      description: Objeto utilizado para conter os parametros para geração de relatório
      required:
      - modelo
      - formato
      type: object
      properties:
        modelo:
          description: Nome do modelo Jasper Reports.
          type: string
        formato:
          description: Formato de exportação (“word” ou “pdf”)
          type: string
        dados:
          description: "Objeto JSON genérico opcional com chaves e valores (para campos\
            \ simples) e arrays (para tabelas/grids, opcional), sem restrição a uma\
            \ estrutura específica, permitindo uso com qualquer modelo Jasper Reports."
          type: object
          additionalProperties: {}
          example:
            cidade: brasilia
            número: "512"
    v1.documento.MinutaDTO:
