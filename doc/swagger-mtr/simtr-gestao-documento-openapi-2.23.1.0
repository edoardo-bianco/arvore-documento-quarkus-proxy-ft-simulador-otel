                    example: dd/MM/yyyy HH:mm:ss
                  matricula_captura:
                    description: Matricula do usuário responsável pela captura do
                      documento.
                    type: string
                    example: c999999
                  data_hora_validade:
                    description: Data/Hora da validade do documento.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  path_storage:
                    description: "Path do documento no storage, trazendo o primeiro\
                      \ da seguinte ordem: Reuso / Tratado / Recebido."
                    type: string
                  mime_type:
                    type: string
                    xml:
                      name: mime_type
                  outsourcing:
                    description: Objeto com o resultado dos serviços de outsourcing..
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.OutSourcingDTO3'
                  atributos:
                    description: Lista de atributos extraidos do documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.AtributoDTO1'
                  assinaturas_digitais:
                    description: Lista de assinaturas digitais vinculadas ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.AssinaturaDigitalDTO3'
                  conformidade:
                    description: Lista de conformidades do documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ConformidadeDTO1'
                  url:
                    description: Url para obter documento.
                    type: string
                  etapa_fluxo:
                    description: Nome descritivo da etapa na qual se encontra o documento.
                    type: string
                  data_hora_etapa_fluxo:
                    description: Momento que ocorreu a etapa no fluxo.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  propriedades:
                    description: Lista de propriedades vinculadas ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.PropriedadeDocumentoDTO1'
                  armazenamento:
                    description: Lista de armazenamento vinculado ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ArmazenamentoDTO'
                  quantidade_bytes:
                    format: int64
                    description: Lista de propriedades vinculadas ao documento.
                    type: integer
                    example: 0
        "401":
          description: Usuário ou canal não autenticado.
        "403":
          description: Usuário ou canal não autorizado a utilizar o serviço.
        "404":
          description: Recurso não localizado para os parâmetros informados.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "500":
          description: Falha não mapeada. Entre em contato com a equipe de desenvolvimento
            do SIMTR encaminhando o log recebido.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
                type: object
                properties:
                  codigo_http:
                    format: int32
                    description: Codigo HTTP definido para identificar o tipo de problema
                      apresentado.
                    type: integer
                  recurso:
                    description: Identificador ou path do recurso já existente em
                      conflito.
                    type: string
                  id_erro:
                    description: Identificador univoco do erro.
                    type: string
                  codigo_erro:
                    description: Codigo de erro fornecido pela aplicação visando permitir
                      o tratamento de um determinado comportamento mais especifico
                      pelo consumidor.
                    type: string
                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "503":
          description: Serviço de terceiros indisponível no momento.
      security:
      - apikey: []
components:
  schemas:
    AlterarAtributoDocumentoDTO:
      required:
      - chave
      - valor
      - objeto
      - opcoes_selecionadas
      - excluir
      type: object
      properties:
        chave:
          description: Chave do atributo.
          type: string
        valor:
          description: Valor do atributo do documento no caso de atributos objetivos.
            Se utilizado o elemento "opcoes_selecionadas" não deve ser informado
          type: string
          example: string
        objeto:
          description: array do atributo do documento
          type: string
        opcoes_selecionadas:
          description: Valor da opção selecionada no caso de atributos objetivos.
            Se utilizado o elemento "valor" não deve ser informado
          type: array
          items:
            type: string
        excluir:
          description: Valor para definir se a propriedade deve ser excluída.
          type: boolean
    AlterarPropriedadeDocumentoDTO:
      required:
      - chave
      - valor
      - objeto
      type: object
      properties:
        chave:
          description: Chave da propriedade.
          type: string
        valor:
          description: Valor da propriedade do documento.
          type: string
        objeto:
          description: array do atributo do documento
          type: string
        excluir:
          description: Valor para definir se a propriedade deve ser excluída.
          type: boolean
    Calendar:
      type: object
      properties:
        fields:
          type: array
          items:
            format: int32
            type: integer
        isSet:
          type: array
          items:
            type: boolean
        time:
          format: int64
          type: integer
        isTimeSet:
          type: boolean
        areFieldsSet:
          type: boolean
        lenient:
          type: boolean
        zone:
          $ref: '#/components/schemas/TimeZone'
        firstDayOfWeek:
          format: int32
          type: integer
        minimalDaysInFirstWeek:
          format: int32
          type: integer
        nextStamp:
          format: int32
          type: integer
        serialVersionOnStream:
          format: int32
          type: integer
        timeInMillis:
          format: int64
          type: integer
        setStateFields:
          format: int32
          type: integer
        fieldsComputed:
          format: int32
          type: integer
        fieldsNormalized:
          format: int32
          type: integer
        partiallyNormalized:
          type: boolean
        fullyNormalized:
          type: boolean
        calendarType:
          type: string
        timeZone:
          $ref: '#/components/schemas/TimeZone'
        zoneShared:
          type: boolean
        weekDateSupported:
          type: boolean
        weekYear:
          format: int32
          type: integer
        weeksInWeekYear:
          format: int32
          type: integer
        weekCountData:
          $ref: '#/components/schemas/Locale'
    CodigoRejeicaoEnum:
      enum:
      - DOC001
      - DOC002
      - DOC003
      - DOC004
      - DOC005
      - DOC006
      - FMT001
      - TIP001
      - TIP002
      - TIP003
      - NEG001
      - NEG002
      - NEG003
      - ARM001
      - IA001
      - IA002
      - IA003
      - IA004
      - IA005
      - IA006
      type: string
    DestinoDocumentoDTO:
      type: object
      properties:
        localGravacao:
          $ref: '#/components/schemas/SiecmLocalGravacaoEnum'
        idDestino:
          type: string
        subPasta:
          type: string
      xml:
        name: DestinoDocumento
    ECMAtributosDocumentoDTO:
      type: object
      properties:
        classe:
          type: string
        gerarThumbnail:
          type: boolean
        tipo:
          type: string
        mimeType:
          type: string
        nome:
          type: string
        campo:
          type: array
          items:
            $ref: '#/components/schemas/v1.siecm.AtributosDTO1'
          xml:
            name: campo
            wrapped: true
      xml:
        name: atributos
    ECMDocumentoDTO:
      type: object
      properties:
        atributos:
          $ref: '#/components/schemas/ECMAtributosDocumentoDTO'
        binario:
          type: string
      xml:
        name: Documento
    ErrorMessage:
      type: object
      properties:
        mensagem:
          description: Mensagem de identificação do problema.
          type: string
    JanelaTemporalExtracaoEnum:
      enum:
      - M0
      - M30
      - M60
      type: string
    LocalDateTime:
      format: date-time
      type: string
      example: 2022-03-10T12:15:50
    Locale:
      type: object
      properties:
        language:
          type: string
        script:
          type: string
        country:
          type: string
        variant:
          type: string
        extensionKeys:
          uniqueItems: true
          type: array
          items:
            format: byte
            type: string
        unicodeLocaleAttributes:
          uniqueItems: true
          type: array
          items:
            type: string
        unicodeLocaleKeys:
          uniqueItems: true
          type: array
          items:
            type: string
        iSO3Language:
          type: string
        iSO3Country:
          type: string
        displayLanguage:
          type: string
        displayScript:
          type: string
        displayCountry:
          type: string
        displayVariant:
          type: string
        displayName:
          type: string
    RetornoErroDTO:
      description: Objeto utilizado para representar falhas nas requisições e devolver
        a indicação do problema para o usuário.
      type: object
      properties:
        codigo_http:
          format: int32
          description: Codigo HTTP definido para identificar o tipo de problema apresentado.
          type: integer
        recurso:
          description: Identificador ou path do recurso já existente em conflito.
          type: string
        id_erro:
          description: Identificador univoco do erro.
          type: string
        codigo_erro:
          description: Codigo de erro fornecido pela aplicação visando permitir o
            tratamento de um determinado comportamento mais especifico pelo consumidor.
          type: string
        erros:
          description: Lista de mensagens de erros.
          type: array
          items:
            $ref: '#/components/schemas/ErrorMessage'
        detalhe:
          description: Detalhamento da causa do ocorrido e possivelmente proposta
            de solução.
          type: string
        stacktrace:
          description: Pilha de erro apresentada pela exceção ocorrida.
          type: string
    SiecmLocalGravacaoEnum:
      enum:
      - PADRAO
      - DOSSIE
      - TRANSACAO
      type: string
    SubPastaDTO:
      type: object
      properties:
        nomeSubPasta:
          type: string
        identificadoresDocumento:
          type: array
          items:
            type: string
          xml:
            name: identificadoresDocumento
            wrapped: true
      xml:
        name: ListaDocumentosCliente
    TimeZone:
      type: object
      properties:
        ID:
          type: string
        rawOffset:
          format: int32
          type: integer
        iD:
          type: string
        displayName:
          type: string
        dSTSavings:
          format: int32
          type: integer
    TipoArmazenamentoDocumentoEnum:
      enum:
      - GED_RECEBIDO
      - GED_TRATADO
      - GED_REUSO
      - STORAGE_RECEBIDO
      - STORAGE_TRATADO
      type: string
    TipoComplexidadeEnum:
      enum:
      - S
      - C
      type: string
    TipoPessoaEnum:
      enum:
      - F
      - J
      - A
      type: string
    TipoTokenSas:
      enum:
      - CONTA
      - CONTAINER
      - BLOB
      type: string
    v1.armazenamento.ContainerDTO:
      description: Objeto utilizado para representar um tokes SAS de um serviço de
        blob storage.
      required:
      - sas
      - validade
      - url_storage
      - tipo_token_sas
      type: object
      properties:
        sas:
          description: tokes SAS de um serviço de blob storage.
          type: string
        validade:
          description: Data/Hora de exipiração do token SAS.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        url_storage:
          description: URL  do endpoint do serviço de blob storage.
          type: string
        tipo_token_sas:
          description: Tipo do tokes SAS de um serviço de blob storage.
          type: string
          allOf:
          - $ref: '#/components/schemas/TipoTokenSas'
        nome:
          description: Nome do container.
          type: string
    v1.armazenamento.CotainerListaDTO:
      description: Objeto utilizado para representar o container.
      required:
      - nome
      - acesso
      - ultima_alteracao
      type: object
      properties:
        nome:
          description: Nome do container.
          type: string
        acesso:
          description: Nivel de acesso do conteiner.
          type: string
        ultima_alteracao:
          description: Data da ultima alteração do container.
          type: string
          allOf:
          - $ref: '#/components/schemas/LocalDateTime'
    v1.armazenamento.UrlBlobDTO:
      description: Objeto utilizado para representar URL de documentos com acesso
        para download.
      required:
      - url_storage
      - validade
      - quantidadeBytes
      type: object
      properties:
        url_storage:
          description: URL do endpoint do serviço de blob storage.
          type: string
        validade:
          description: Data/Hora de exipiração da URL.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        quantidadeBytes:
          format: int64
          description: Quantidade de bytes do documento.
          type: integer
          example: 0
    v1.documento.ApontamentoDTO:
      description: Objeto utilizado para representar apontamento relacionado a um
        checklist.
      required:
      - id
      - identificador_negocial
      - nome
      - tipo
      - complexidade
      - aprovado
      - orientacao
      - comentario
      type: object
      properties:
        id:
          format: int64
          description: Identificador único do apontamento.
          type: integer
        identificador_negocial:
          format: int64
          description: Identificador negocial do apontamento.
          type: integer
        nome:
          description: Nome do apontamento.
          type: string
        tipo:
          description: Tipo do apontamento.
          type: string
        complexidade:
          description: Tipo do apontamento.
          type: string
          allOf:
          - $ref: '#/components/schemas/TipoComplexidadeEnum'
        aprovado:
          description: Representa se um apontamento foi aprovado.
          type: boolean
        orientacao:
          description: Orientação do apontamento.
          type: string
        comentario:
          description: Comentário do apontamento.
          type: string
    v1.documento.ApontamentoDTO1:
      description: Objeto utilizado para representar apontamento relacionado a um
        checklist.
      required:
      - id
      - identificador_negocial
      - nome
      - tipo
      - complexidade
      - aprovado
      - orientacao
      - comentario
      type: object
      properties:
        id:
          format: int64
          description: Identificador único do apontamento.
          type: integer
        identificador_negocial:
          format: int64
          description: Identificador negocial do apontamento.
          type: integer
        nome:
          description: Nome do apontamento.
          type: string
        tipo:
          description: Tipo do apontamento.
          type: string
        complexidade:
          description: Tipo do apontamento.
          type: string
          allOf:
          - $ref: '#/components/schemas/TipoComplexidadeEnum'
        aprovado:
          description: Representa se um apontamento foi aprovado.
          type: boolean
        orientacao:
          description: Orientação do apontamento.
          type: string
        comentario:
          description: Comentário do apontamento.
          type: string
    v1.documento.ArmazenamentoDTO:
      description: Objeto utilizado para representar o histórico de armazenamento
        de um documento.
      required:
      - id
      - data_hora_armazenamento
      - tipo_armazenamento
      - path_storage
      - object_store_ged
      - codigo_ged
      - data_hora_previsao_exclusao
      - data_hora_exclusao
      type: object
      properties:
        id:
          format: int64
          description: Id do armazenamento.
          type: integer
        data_hora_armazenamento:
          description: Data hora do documento armazenado.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        tipo_armazenamento:
          description: Tipo do documento armazenado.
          type: string
          allOf:
          - $ref: '#/components/schemas/TipoArmazenamentoDocumentoEnum'
        path_storage:
          description: Path Storage do documento armazenado.
          type: string
        object_store_ged:
          description: Object Storage do documento armazenado.
          type: string
        codigo_ged:
          description: Codigo Ged do documento armazenado.
          type: string
        data_hora_previsao_exclusao:
          description: Data hora previsão da exclusao do documento armazenado.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_exclusao:
          description: Data hora da exclusao do documento armazenado.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
    v1.documento.AssinaturaDigitalDTO:
