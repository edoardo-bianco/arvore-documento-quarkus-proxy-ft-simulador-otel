  /simtr-gestao-documento/v1/storage/container/credencial:
    post:
      tags:
      - Negócio - Storage
      description: Gera uma nova credencial de acesso compartilhado (SAS) para um
        container de armazenamento de documentos no Storage.
      responses:
        "200":
          description: Credencial SAS gerado com sucesso.
          content:
            application/json:
              schema:
                description: Gera uma nova assinatura de acesso compartilhado (SAS)
                  para um container de armazenamento de documentos no Storage.
                required:
                - sas
                - validade
                - url_storage
                type: object
                properties:
                  sas:
                    description: tokes SAS de um serviço de blob storage.
                    type: string
                  validade:
                    description: Data/Hora de exipiração do token SAS.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  url_storage:
                    description: URL do endpoint do serviço de blob storage.
                    type: string
                  nome_container:
                    description: Nome do container.
                    type: string
        "401":
          description: Usuário ou canal não autenticado.
        "403":
          description: Usuário ou canal não autorizado a utilizar o serviço.
        "500":
          description: Falha não mapeada. Entre em contato com a equipe de desenvolvimento
            do SIMTR encaminhando o log recebido.
