          type: string
          allOf:
          - $ref: '#/components/schemas/TipoPessoaEnum'
        indicador_minuta_pdf:
          description: Indica se a tipologia permite a geração de minuta.
          type: boolean
    v1.documento.paginacao.DocumentoConsultaPropriedadeDTO:
      description: Objeto utilizado para representar o corpo da consulta de documento.
      required:
      - propriedades
      - cpf
      - cnpj
      - inclui_inativos
      - inclui_nao_validados
      - inclui_url
      - ip_usuario
      type: object
      properties:
        propriedades:
          description: Objeto utilizado para representar o corpo da consulta de documento
            por propriedades.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.paginacao.DocumentoConsultaPropriedadeDTO1'
        cpf:
          description: Cpf vinculado ao documento.
          type: string
        cnpj:
          description: Cnpj vinculado ao documento.
          type: string
        tipologia:
          description: Tipologia vinculado ao documento.
          type: string
        inclui_atributos:
          description: Indica se deve ser incluído no retorno os atributos extraídos
            do documento.
          type: boolean
          example: false
        inclui_assinaturas:
          description: Indica se deve ser incluído no retorno as assinaturas digitais
            do documento.
          type: boolean
          example: false
        inclui_outsourcing:
          description: Indica se deve ser incluído no retorno os serviços de outsourcing
            realizados para o documento.
          type: boolean
          example: false
        inclui_conformidade:
          description: "Indica se deve ser incluído no retorno um resumo das verificaç\
            ões de conformidade realizadas para o documento, sejam elas realizadas\
            \ pela área de operações internas da Caixa ou por fornecedor externo."
          type: boolean
          example: false
        inclui_armazenamento:
          description: Indica se deve ser incluído no retorno o historico de armazenamento
            do documento.
          type: boolean
          example: false
        inclui_propriedades:
          description: Indica se deve ser incluído no retorno as propriedades extraídas
            do documento.
          type: boolean
          example: false
        inclui_inativos:
          description: "Indica se deve ser incluído no retorno os documentos inativos\
            \ (Rejeitado, Vencido, Indício de Fraude)."
          type: boolean
          example: false
        inclui_nao_validados:
          description: Indica se deve ser incluído no retorno os documentos não validados
            (Criados).
          type: boolean
          example: false
        inclui_url:
          description: "Indica se deve ser incluído no retorno uma URL de consulta\
            \ da imagem do documento, de uso exclusivo pelo IP do usuário ou canal\
            \ requisitante."
          type: boolean
          example: false
        ip_usuario:
          description: IP do usuário final ou canal que consultará a URL do documento.
            O GED possui validação de IP na consulta de documentos. Caso não enviado
            este parâmetro será utilizado o IP existente no header da requisição.
          type: string
    v1.documento.paginacao.DocumentoConsultaPropriedadeDTO1:
      description: Objeto utilizado para representar o corpo da consulta de documento
        por propriedades.
      required:
      - chave
      - valor
      type: object
      properties:
        chave:
          description: Chave da propriedade.
          type: string
        valor:
          description: Valor da propriedade.
          type: string
    v1.documento.paginacao.PaginacaoDTO:
      description: Objeto utilizado para representar a paginacao.
      required:
      - pagina
      - registro_pagina
      - total_paginas
      - total_registros_encontrados
      type: object
      properties:
        pagina:
          format: int64
          description: Pagina.
          type: integer
        registro_pagina:
          format: int32
          description: Registro da Pagina.
          type: integer
        total_paginas:
          format: int64
          description: Quantitativo total de paginas.
          type: integer
        total_registros_encontrados:
          format: int64
          description: Quantitativo total de registros encontrados.
          type: integer
    v1.dossie.ECMCriaDossieDTO:
      description: Objeto utilizado para representar a Requisição para criar uma pasta
        de dossiê no repositório no corporativo de documento CAIXA.
      type: object
      properties:
        dadosRequisicao:
          $ref: '#/components/schemas/v1.siecm.DadosRequisicaoDTO'
        idDossie:
          type: string
      xml:
        name: CriaDossie
    v1.negocio.dossiecliente.manutencao.MotivoReprovacaoDTO:
      description: Objeto utilizado para representar um atributo com o valor extraido
        de um documento ou como dados de ajuste para atualização da informação perante
        o documento.
      required:
      - motivo_reprovacao
      type: object
      properties:
        motivo_reprovacao:
          description: Nome do atributo do documento
          type: string
    v1.negocio.dossiecliente.manutencao.ProdutoAvalidadorTomadorDTO:
      description: Objeto utilizado para representar um atributo com o valor extraido
        de um documento ou como dados de ajuste para atualização da informação perante
        o documento.
      required:
      - rating
      - codigo_modalidade
      - codigo_produto
      - resultado_avaliacao
      - valor_disponivel
      - valor_calculado_total
      - prazo_meses
      type: object
      properties:
        rating:
          description: Nome do atributo do documento.
          type: string
        codigo_modalidade:
          description: Valor do atributo do documento
          type: string
        codigo_produto:
          description: Valor do atributo do documento
          type: string
        resultado_avaliacao:
          description: Valor do atributo do documento
          type: string
        valor_disponivel:
          description: Valor do atributo do documento
          type: string
        valor_calculado_total:
          description: Valor do atributo do documento
          type: string
        prazo_meses:
          description: Valor do atributo do documento
          type: string
    v1.siecm.AtributosDTO:
      description: "."
      required:
      - id
      - classe
      - campo
      - tipo
      - mimeType
      - nome
      type: object
      properties:
        id:
          description: "Identificador do documento, para uso em outras ações, como\
            \ alteração e inclusão em pastas."
          type: string
        classe:
          description: Classe documental a qual o documento pesquisado pertence .
          type: string
        campo:
          description: Campos relacionandos a um atributo de documento.
          type: array
          items:
            $ref: '#/components/schemas/v1.siecm.AtributosDTO1'
        tipo:
          description: "Tipo do documento. Ex: PDF. ."
          type: string
        mimeType:
          description: MimeType do documento.
          type: string
        nome:
          description: Nome do documento.
          type: string
        campos:
          type: array
          items:
            $ref: '#/components/schemas/v1.siecm.AtributosDTO1'
    v1.siecm.AtributosDTO1:
      description: "."
      required:
      - nome
      - valor
      - tipo
      type: object
      properties:
        nome:
          description: Nome do campo.
          type: string
        valor:
          description: Valor do campo.
          type: string
        tipo:
          description: Tipo do campo.
          type: string
    v1.siecm.DadosDocumentoLocalizadoDTO:
      description: "."
      required:
      - link
      - atributos
      type: object
      properties:
        link:
          description: Ticket de acesso ao documento requisitado.
          type: string
        atributos:
          description: Atributos do documento requisitado.
          type: object
          allOf:
          - $ref: '#/components/schemas/v1.siecm.AtributosDTO'
    v1.siecm.DadosRequisicaoDTO:
      description: Objeto utilizado para representar os dados fornecidos para consulta
        de documentos no siecm.
      required:
      - localArmazenamento
      - ipUsuarioFinal
      type: object
      properties:
        localArmazenamento:
          description: "."
          type: string
        ipUsuarioFinal:
          description: "."
          type: string
    v1.siecm.ECMAtualizaIndicesDocumentoDTO:
      description: Objeto utilizado para representar a Requisição para atualizar os
        índices de um documento.
      type: object
      properties:
        dadosRequisicao:
          $ref: '#/components/schemas/v1.siecm.DadosRequisicaoDTO'
        identificadorDocumento:
          type: string
        campo:
          type: array
          items:
            $ref: '#/components/schemas/v1.siecm.AtributosDTO1'
          xml:
            name: campo
            wrapped: true
      xml:
        name: AtualizaIndicesDocumento
    v1.siecm.ECMGravaDocumentoDTO:
      description: Objeto utilizado para representar a Requisi��o para gravar documentos
        no reposit�rio corporativo de documento CAIXA.
      type: object
      properties:
        dadosRequisicao:
          $ref: '#/components/schemas/v1.siecm.DadosRequisicaoDTO'
        destinoDocumento:
          $ref: '#/components/schemas/DestinoDocumentoDTO'
        documento:
          $ref: '#/components/schemas/ECMDocumentoDTO'
      xml:
        name: GravaDocumento
    v1.siecm.ECMLocalizaDocumentoDTO:
      description: Objeto utilizado para representar os dados fornecidos para consulta
        de documentos no siecm.
      required:
      - dadosRequisicao
      - id
      type: object
      properties:
        dadosRequisicao:
          description: Dados da Requisiçao.
          type: object
          allOf:
          - $ref: '#/components/schemas/v1.siecm.DadosRequisicaoDTO'
        id:
          description: Id do documento
          type: string
    v1.siecm.ECMRespostaDTO:
      description: Objeto utilizado para representar os dados fornecidos para consulta
        de documentos no siecm.
      type: object
      properties:
        operacao:
          type: string
        codigoRetorno:
          format: int32
          type: integer
        mensagem:
          type: string
    v1.siecm.RetornoPesquisaDTO:
      description: Objeto utilizado para representar o resultado de um Documento submetido
        aos serviços de outsourcing documental.
      required:
      - quantidade
      - dadosDocumentoLocalizado
      - codigoRetorno
      - mensagem
      type: object
      properties:
        quantidade:
          format: int32
          description: Quantidade de documentos encontrados .
          type: integer
        dadosDocumentoLocalizado:
          description: Representa o documento retornado na requisição.
          type: array
          items:
            $ref: '#/components/schemas/v1.siecm.DadosDocumentoLocalizadoDTO'
        codigoRetorno:
          format: int32
          description: Codigo de retorno da requisiçao.
          type: integer
        mensagem:
          description: Mensagem com o retorno da requisição.
          type: string
    v1.storage.CaminhoDocumentoCanalDTO:
      description: Objeto com o caminho do documento armazenado no Storage.
      required:
      - caminho_documento
      type: object
      properties:
        caminho_documento:
          description: Caminho do documento no Storage
          type: string
    v1.storage.ContainerDTO:
      description: Objeto utilizado para representar o container.
      required:
      - nome
      type: object
      properties:
        nome:
          description: "Nome do container que deve ser criado. O nome deve ser composto\
            \ de apenas letras minúsculas, números e hífen. O tamanho mínimo é de\
            \ 3 caracteres e o máximo é de 63 caracteres."
          type: string
    v1.storage.DocumentoDTO:
      description: Documento que será armazenado no container.
      required:
      - binario
      type: object
      properties:
        binario:
          description: Binário em base64 do documento para ser armazenado no container.
          type: string
    v1.storage.TokenSasDTO:
      description: Gera uma nova assinatura de acesso compartilhado (SAS) para um
        container de armazenamento de documentos no Storage.
      required:
      - sas
      - validade
      - url_storage
      type: object
      properties:
        sas:
          description: tokes SAS de um serviço de blob storage.
          type: string
        validade:
          description: Data/Hora de exipiração do token SAS.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        url_storage:
          description: URL do endpoint do serviço de blob storage.
          type: string
        nome_container:
          description: Nome do container.
          type: string
    v1.storage.UrlBlobDTO:
      description: Obtém a URL de acesso de um documento no Storage.
      required:
      - url
      - validade_url
      type: object
      properties:
        url:
          description: URL do endpoint do serviço de blob storage.
          type: string
        validade_url:
          description: Data/Hora de exipiração da URL.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
    v1.transacao.ECMCriaTransacaoDTO:
      description: Objeto utilizado para representar a Requisição para criar uma pasta
        de transação no repositório no corporativo de documento CAIXA.
      type: object
      properties:
        dadosRequisicao:
          type: object
          allOf:
          - $ref: '#/components/schemas/v1.siecm.DadosRequisicaoDTO'
          xml:
            name: dadosRequisicao
        idTransacao:
          type: string
        subPasta:
          type: array
          items:
            $ref: '#/components/schemas/SubPastaDTO'
          xml:
            wrapped: true
      xml:
        name: CriaTransacao
    v2.documento.paginacao.DocumentoConsultaPropriedadeDTO:
      description: Objeto utilizado para representar o corpo da consulta de documento.
      type: object
      properties:
        solicitacao:
          description: "Código único para o canal para a solicitação, quando esta\
            \ envolve mais de um documento. Os documentos recebidos em uma mesma solicitaç\
            ão possuem um retorno único de callback para o canal."
          type: string
          example: "123"
        sigla_canal:
          description: Sigla do canal.
          type: string
          example: SICTD
        codigo_canal:
          description: Identificador do documento junto ao canal.
          type: string
          example: "456"
        codigo_fornecedor:
          description: Codigo do fornecedor.
          type: string
        sigla_fornecedor:
          description: 'Sigla do fornecedor. '
          type: string
        codigo_controle:
          format: int64
          description: Codigo do controle de documento.
          type: integer
        propriedades:
          description: Objeto utilizado para representar o corpo da consulta de documento
            por propriedades.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.paginacao.DocumentoConsultaPropriedadeDTO1'
        cpf:
          description: Cpf vinculado ao documento.
          type: string
        cnpj:
          description: Cnpj vinculado ao documento.
          type: string
        tipologia:
          description: Tipologia vinculado ao documento.
          type: string
        inclui_atributos:
          description: Indica se deve ser incluído no retorno os atributos extraídos
            do documento.
          type: boolean
          example: false
        inclui_assinaturas:
          description: Indica se deve ser incluído no retorno as assinaturas digitais
            do documento.
          type: boolean
          example: false
        inclui_outsourcing:
          description: Indica se deve ser incluído no retorno os serviços de outsourcing
            realizados para o documento.
          type: boolean
          example: false
        inclui_conformidade:
          description: "Indica se deve ser incluído no retorno um resumo das verificaç\
            ões de conformidade realizadas para o documento, sejam elas realizadas\
            \ pela área de operações internas da Caixa ou por fornecedor externo."
          type: boolean
          example: false
        inclui_armazenamento:
          description: Indica se deve ser incluído no retorno o historico de armazenamento
            do documento.
          type: boolean
          example: false
        inclui_propriedades:
          description: Indica se deve ser incluído no retorno as propriedades extraídas
            do documento.
          type: boolean
          example: false
        inclui_inativos:
          description: "Indica se deve ser incluído no retorno além dos documentos\
            \ na situação Reuso os documentos inativos também (Rejeitado, Vencido,\
            \ Indício de Fraude)"
          type: boolean
          example: false
        inclui_nao_validados:
          description: Indica se deve ser incluído além dos documentos na situação
            Reuso os documentos não validados (Criados e Conforme).
          type: boolean
          example: false
        inclui_url:
          description: "Indica se deve ser incluído no retorno uma URL de consulta\
            \ da imagem do documento, de uso exclusivo pelo IP do usuário ou canal\
            \ requisitante."
          type: boolean
          example: false
        ip_usuario:
          description: IP do usuário final ou canal que consultará a URL do documento.
            O GED possui validação de IP na consulta de documentos. Caso não enviado
            este parâmetro será utilizado o IP existente no header da requisição.
          type: string
        ordem:
          description: "São oferecidos três opções de ordenação: \"data-captura-asc\"\
            , \"data-captura-desc\" e \"ultima-alteracao\". Quando não informado a\
            \ ordenação na solicitação o sistema não realiza uma ordenação dos resultados."
          type: string
        pagina:
          format: int32
          description: "Quando não informado a página na solicitação o sistema apresenta\
            \ o total de páginas, o total de registros e são listados o 50 primeiros\
            \ documentos(\"pagina\":1) conforme o tipo de ordenação informado na solicitaç\
            ão, para consultar outras páginas, basta informar no atributo \"pagina\"\
            \ o número da página que deseja consultar e enviar a solicitação novamente."
          type: integer
          example: 1
        itens_por_pagina:
          format: int32
          description: Indica quantos documentos devem ser incluídos em cada 'página'
            de resposta. O padrão é 50 itens caso não seja enviado.
          type: integer
          example: 50
  securitySchemes:
    SSO_intranet:
      type: oauth2
      description: "Token utilizado por aplicacoes client Credentials autenticados\
        \ no SSO da Caixa Intranet. O token de acesso deve conter:\n* a claim **\"\
        preferred_username\"** \n"
      flows:
        password:
          tokenUrl: https://login.des.caixa/auth/realms/intranet/protocol/openid-connect/token
          scopes:
            openid: openid scope
        clientCredentials:
          tokenUrl: https://login.des.caixa/auth/realms/intranet/protocol/openid-connect/token
          scopes:
            openid: openid scope
    apikey:
      type: apiKey
      description: Identificador da aplicação no api gateway
      name: apikey
      in: header
    SecurityScheme:
      type: openIdConnect
      description: Authentication
      openIdConnectUrl: https://login.des.caixa/auth/realms/intranet/.well-known/openid-configuration
