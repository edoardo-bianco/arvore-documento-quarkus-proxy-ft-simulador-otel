                  erros:
                    description: Lista de mensagens de erros.
                    type: array
                    items:
                      $ref: '#/components/schemas/ErrorMessage'
                  detalhe:
                    description: Detalhamento da causa do ocorrido e possivelmente
                      proposta de solução.
                    type: string
                  stacktrace:
                    description: Pilha de erro apresentada pela exceção ocorrida.
                    type: string
        "401":
          description: Usuário ou canal não autenticado.
        "403":
          description: Usuário ou canal não autorizado a utilizar o serviço.
        "404":
          description: Recurso não localizado para os parâmetros informados.
