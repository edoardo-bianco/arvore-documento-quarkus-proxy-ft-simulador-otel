    v1.documento.PropriedadeDocumentoDTO:
      description: Objeto utilizado para representar as propriedades de um documento
        ou como retorno ajustados para atualização.
      required:
      - chave
      - valor
      type: object
      properties:
        chave:
          description: Chave do atributo.
          type: string
        valor:
          description: Valor do atributo do documento no caso de atributos objetivos.
            Se utilizado o elemento "opcoes_selecionadas" não deve ser informado
          type: string
    v1.documento.PropriedadeDocumentoDTO1:
      description: Objeto utilizado para representar as propriedades de um documento
        ou como retorno ajustados para atualização.
      required:
      - chave
      - valor
      - objeto
      type: object
      properties:
        chave:
          description: Chave do atributo.
          type: string
        valor:
          description: Valor do atributo do documento no caso de atributos objetivos.
            Se utilizado o elemento "opcoes_selecionadas" não deve ser informado
          type: string
        objeto:
          description: Array do atributo do documento
          type: string
    v1.documento.RespostaDocumentoInclusaoDTO:
      description: Objeto utilizado para representar a inclusão de um Documento.
      required:
      - id
      type: object
      properties:
        id:
          format: int64
          description: 'Identificador único do registro de documento. '
          type: integer
    v1.documento.ResultadoDocumentoDTO:
      description: Objeto utilizado para representar o resultado de um Documento.
      required:
      - pagina
      - registro_pagina
      - total_paginas
      - total_registros_encontrados
      - retorno_consulta
      type: object
      properties:
        pagina:
          format: int64
          description: Pagina.
          type: integer
        registro_pagina:
          format: int32
          description: Registro da Pagina.
          type: integer
        total_paginas:
          format: int64
          description: Quantitativo total de paginas.
          type: integer
        total_registros_encontrados:
          format: int64
          description: Quantitativo total de registros encontrados.
          type: integer
        retorno_consulta:
          description: Objeto com o resultado paginado dos documentos solicitados.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.ResultadoDocumentoDTO1'
    v1.documento.ResultadoDocumentoDTO1:
      description: Objeto utilizado para representar o resultado de um Documento.
      required:
      - id
      - tipo_documento
      - situacao_documento
      - canal
      - codigo_ged
      - object_store_ged
      - data_hora_captura
      - matricula_captura
      - data_hora_validade
      - etapa_fluxo
      - data_hora_etapa_fluxo
      - outsourcing
      - atributos
      - assinaturas_digitais
      - conformidade
      - armazenamento
      - propriedades
      - url
      type: object
      properties:
        id:
          format: int64
          description: 'Identificador único do registro de documento. '
          type: integer
        tipo_documento:
          description: Tipo do documento categorizado.
          type: object
          allOf:
          - $ref: '#/components/schemas/v1.documento.TipoDocumentoDTO'
        situacao_documento:
          description: Situação do documento.
          type: string
        canal:
          description: Canal de captura do documento.
          type: object
          allOf:
          - $ref: '#/components/schemas/v1.documento.CanalDTO1'
        codigo_ged:
          description: Identificador do documento perante a solução de GED.
          type: string
        object_store_ged:
          description: Local de armazenamento do documento perante a solução de GED.
          type: string
        data_hora_captura:
          description: Data/Hora de captura do documento.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        matricula_captura:
          description: Matricula do usuário responsável pela captura do documento.
          type: string
          example: c999999
        data_hora_validade:
          description: Data/Hora da validade do documento.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_validacao_assinatura:
          description: Data/Hora da validação de assinatura digital.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        etapa_fluxo:
          description: Nome descritivo da etapa na qual se encontra o documento.
          type: string
        data_hora_etapa_fluxo:
          description: Momento que ocorreu a etapa no fluxo.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        outsourcing:
          description: Objeto com o resultado dos serviços de outsourcing..
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.OutSourcingDTO'
        atributos:
          description: Lista de atributos extraidos do documento.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.AtributoDTO'
        assinaturas_digitais:
          description: Lista de assinaturas digitais vinculadas ao documento.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.AssinaturaDigitalDTO'
        conformidade:
          description: Lista de conformidades do documento.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.ConformidadeDTO'
        armazenamento:
          description: Lista de armazenamento vinculado ao documento.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.ArmazenamentoDTO'
        propriedades:
          description: Lista de propriedades vinculadas ao documento.
          type: array
          items:
            $ref: '#/components/schemas/v1.documento.PropriedadeDocumentoDTO'
        url:
          description: Url para obter documento.
          type: string
