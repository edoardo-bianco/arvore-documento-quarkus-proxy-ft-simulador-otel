  /simtr-gestao-documento/v2/documento/consulta:
    post:
      tags:
      - Negócio - Documento
      description: "Consulta de documentos com parâmetros filtros para retorno. O\
        \ retorno da consulta é paginado e ordenado, essas informações devem ser informadas\
        \ no corpo da solicitação pelos atributos: \"pagina\" e \"ordem\". Por padrã\
        o, a consulta recupera os documentos na situação \"Reuso\"."
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/v2.documento.paginacao.DocumentoConsultaPropriedadeDTO'
      responses:
        "200":
          description: Recurso criado/ alterado/ localizado ou excluído com sucesso.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar o resultado de um Documento.
                required:
                - pagina
                - registro_pagina
                - total_paginas
                - total_registros_encontrados
                - retorno_consulta
                type: object
                properties:
                  pagina:
                    format: int64
                    description: Pagina.
                    type: integer
                  registro_pagina:
                    format: int32
                    description: Registro da Pagina.
                    type: integer
                  total_paginas:
                    format: int64
                    description: Quantitativo total de paginas.
                    type: integer
                  total_registros_encontrados:
                    format: int64
                    description: Quantitativo total de registros encontrados.
                    type: integer
                  retorno_consulta:
                    description: Objeto com o resultado paginado dos documentos solicitados.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ResultadoDocumentoDTO1'
        "204":
          description: Nenhum recurso
        "400":
          description: Falha nas validações da requisição.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
                  e devolver a indicação do problema para o usuário.
