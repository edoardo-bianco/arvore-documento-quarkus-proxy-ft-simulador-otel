    v1.documento.AtualizarAtributoDocumentoDTO:
      description: "Objeto utilizado para representar o atributo, propriedade ou sitiuaç\
        ão a ser atualizado"
      type: object
      properties:
        atributos:
          description: Lista de atributos extraidos do documento.
          type: array
