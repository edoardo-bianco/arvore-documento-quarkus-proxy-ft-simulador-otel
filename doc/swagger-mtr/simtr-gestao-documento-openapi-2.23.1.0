          type: string
          example: string
        objeto:
          description: array do atributo do documento
          type: string
        opcoes_selecionadas:
          description: Valor da opção selecionada no caso de atributos objetivos.
            Se utilizado o elemento "valor" não deve ser informado
          type: array
          items:
            type: string
    v1.documento.AtributoDocumentoMinutaDTO:
      description: Objeto utilizado para representar um atributo para consulta no
