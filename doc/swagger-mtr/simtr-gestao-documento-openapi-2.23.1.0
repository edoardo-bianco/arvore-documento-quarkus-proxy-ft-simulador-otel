        data_hora_envio:
          description: Data/Hora de captura de envio do documento para o fornecedor.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        status_envio:
          description: "Status do envio de outsourcing: Concluido, Andamento, Rejeitado\
            \ ou Erro."
          type: string
        solicitacao_tratamento_imagem:
          description: Indice de solititação de tratamento de imagem documental.
          type: boolean
        solicitacao_extracao:
          description: Indice de solititação da extração documental.
          type: boolean
        solicitacao_validacao_negocial:
          description: Indice de solititação de validação negocial documental.
          type: boolean
