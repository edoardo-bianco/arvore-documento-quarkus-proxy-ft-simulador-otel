    v1.documento.AtributoDTO:
      description: Objeto utilizado para representar os atributos de um documento
        ou como retorno ajustados para atualização.
      required:
      - chave
      - valor
      - opcoes_selecionadas
      type: object
      properties:
        chave:
          description: Chave do atributo.
          type: string
        valor:
          description: Valor do atributo do documento no caso de atributos objetivos.
            Se utilizado o elemento "opcoes_selecionadas" não deve ser informado
          type: string
          example: fulano de tal
        opcoes_selecionadas:
          description: Valor da opção selecionada no caso de atributos objetivos.
            Se utilizado o elemento "valor" não deve ser informado
          type: array
          items:
            type: string
    v1.documento.AtributoDTO1:
      description: Objeto utilizado para representar os atributos de um documento
        ou como retorno ajustados para atualização.
      required:
      - chave
      - valor
      - opcoes_selecionadas
      type: object
      properties:
        chave:
          description: Chave do atributo.
          type: string
        valor:
          description: Valor do atributo do documento no caso de atributos objetivos.
            Se utilizado o elemento "opcoes_selecionadas" não deve ser informado
          type: string
          example: string
        objeto:
          description: Valor do objeto do documento.
          type: string
          example: string
        opcoes_selecionadas:
          description: Valor da opção selecionada no caso de atributos objetivos.
            Se utilizado o elemento "valor" não deve ser informado
          type: array
          items:
            type: string
    v1.documento.AtributoDocumentoDTO:
      description: Objeto utilizado para representar uma propriedade com o valor extraido
        de um documento ou como dados de ajuste para atualização da informação perante
        o documento
      required:
      - chave
      - valor
      - excluir
      - objeto
      type: object
      properties:
        chave:
          description: Chave da propriedade.
          type: string
        valor:
          description: Valor da propriedade do documento.
          type: string
        excluir:
          description: Se a propriedade é marcada para exclusão.
          type: boolean
        objeto:
          description: array do atributo do documento
          type: string
    v1.documento.AtributoDocumentoDTO1:
      description: Objeto utilizado para representar um atributo com o valor extraido
        de um documento ou como dados de ajuste para atualização da informação perante
        o documento
      required:
      - chave
      - valor
      - objeto
      - excluir
      type: object
      properties:
        chave:
          description: Chave do atributo.
          type: string
        valor:
          description: Valor do atributo do documento no caso de atributos objetivos.
            Se utilizado o elemento "opcoes_selecionadas" não deve ser informado
          type: string
          example: string
        objeto:
          description: array do atributo do documento
          type: string
        excluir:
          description: array do atributo do documento
          type: boolean
        opcoes_selecionadas:
          description: Valor da opção selecionada no caso de atributos objetivos.
            Se utilizado o elemento "valor" não deve ser informado
          type: array
          items:
            type: string
    v1.documento.AtributoDocumentoDTO2:
      description: Objeto utilizado para representar uma propriedade com o valor extraido
        de um documento ou como dados de ajuste para atualização da informação perante
        o documento
      required:
      - chave
      - valor
      - objeto
      type: object
      properties:
        chave:
          description: Chave da propriedade.
          type: string
        valor:
          description: Valor da propriedade do documento.
          type: string
        objeto:
          description: array do atributo do documento
          type: string
    v1.documento.AtributoDocumentoDTO3:
      description: Objeto utilizado para representar um atributo com o valor extraido
