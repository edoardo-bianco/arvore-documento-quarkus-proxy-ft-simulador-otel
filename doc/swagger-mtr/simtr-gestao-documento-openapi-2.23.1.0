  /simtr-gestao-documento/v2/documento/{id}:
    get:
      tags:
      - Negócio - Documento
      description: "Consulta de um documento, podendo ser utilizados parâmetros para\
        \ incrementar o retorno com as informações específicas necessárias."
      parameters:
      - name: id
        in: path
        description: Identificador do documento na base de dados do SIMTR.
        required: true
        schema:
          format: int64
          type: integer
      - name: inclui-armazenamento
        in: query
        description: Indica se deve ser incluído no retorno o historico de armazenamento
          do documento.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-assinaturas
        in: query
        description: Indica se deve ser incluído no retorno as assinaturas digitais
          do documento.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-atributos
        in: query
        description: Indica se deve ser incluído no retorno os atributos extraídos
          do documento.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-conformidade
        in: query
        description: "Indica se deve ser incluído no retorno um resumo das verificaç\
          ões de conformidade realizadas para o documento, sejam elas realizadas pela\
          \ área de operações internas da Caixa ou por fornecedor externo."
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-outsourcing
        in: query
        description: Indica se deve ser incluído no retorno os serviços de outsourcing
          realizados para o documento.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-propriedades
        in: query
        description: Indica se deve ser incluído no retorno as propriedades extraídas
          do documento.
        required: false
        schema:
          default: "false"
          type: boolean
      - name: inclui-url
        in: query
        description: "Indica se deve ser incluído no retorno uma URL de consulta da\
          \ imagem do documento, de uso exclusivo pelo IP do usuário ou canal requisitante."
        required: false
        schema:
          default: "false"
          type: boolean
      - name: ip-usuario
        in: query
        description: IP do usuário final ou canal que consultará a URL do documento.
          O GED possui validação de IP na consulta de documentos. Caso não enviado
          este parâmetro será utilizado o IP existente no header da requisição.
        required: false
        schema:
          default: ""
          type: string
      responses:
        "200":
          description: Recurso criado/ alterado/ localizado ou excluído com sucesso.
        "400":
          description: Falha nas validações da requisição.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar o resultado de um Documento.
                required:
                - id
                - tipo_documento
                - situacao_documento
                - canal
                - codigo_ged
                - object_store_ged
                - data_hora_captura
                - matricula_captura
                - data_hora_validade
                - path_storage
                - outsourcing
                - atributos
                - assinaturas_digitais
                - conformidade
                - url
                - etapa_fluxo
                - data_hora_etapa_fluxo
                - propriedades
                - armazenamento
                - quantidade_bytes
                type: object
                properties:
                  id:
                    format: int64
                    description: 'Identificador único do registro de documento. '
                    type: integer
                  tipo_documento:
                    description: Tipo do documento categorizado.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.documento.TipoDocumentoDTO'
                  situacao_documento:
                    description: Situação do Documento.
                    type: string
                  canal:
                    description: Canal de captura do documento.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/v1.documento.CanalDTO1'
                  codigo_ged:
                    description: Identificador do documento perante a solução de GED.
                    type: string
                  object_store_ged:
                    description: Local de armazenamento do documento perante a solução
                      de GED.
                    type: string
                  data_hora_captura:
                    description: Data/Hora de captura do documento.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  data_hora_validacao_assinatura:
                    description: Data/Hora da validação de assinatura digital.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  matricula_captura:
                    description: Matricula do usuário responsável pela captura do
                      documento.
                    type: string
                    example: c999999
                  data_hora_validade:
                    description: Data/Hora da validade do documento.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  path_storage:
                    description: "Path do documento no storage, trazendo o primeiro\
                      \ da seguinte ordem: Reuso / Tratado / Recebido."
                    type: string
                  mime_type:
                    type: string
                    xml:
                      name: mime_type
                  outsourcing:
                    description: Objeto com o resultado dos serviços de outsourcing..
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.OutSourcingDTO2'
                  atributos:
                    description: Lista de atributos extraidos do documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.AtributoDTO1'
                  assinaturas_digitais:
                    description: Lista de assinaturas digitais vinculadas ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.AssinaturaDigitalDTO2'
                  conformidade:
                    description: Lista de conformidades do documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ConformidadeDTO1'
                  url:
                    description: Url para obter documento.
                    type: string
                  etapa_fluxo:
                    description: Nome descritivo da etapa na qual se encontra o documento.
                    type: string
                  data_hora_etapa_fluxo:
                    description: Momento que ocorreu a etapa no fluxo.
                    type: object
                    allOf:
                    - $ref: '#/components/schemas/Calendar'
                    example: dd/MM/yyyy HH:mm:ss
                  propriedades:
                    description: Lista de propriedades vinculadas ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.PropriedadeDocumentoDTO1'
                  armazenamento:
                    description: Lista de armazenamento vinculado ao documento.
                    type: array
                    items:
                      $ref: '#/components/schemas/v1.documento.ArmazenamentoDTO'
                  quantidade_bytes:
                    format: int64
                    description: Lista de propriedades vinculadas ao documento.
                    type: integer
                    example: 0
        "401":
          description: Usuário ou canal não autenticado.
        "403":
          description: Usuário ou canal não autorizado a utilizar o serviço.
        "404":
          description: Recurso não localizado para os parâmetros informados.
          content:
            application/json:
              schema:
                description: Objeto utilizado para representar falhas nas requisições
