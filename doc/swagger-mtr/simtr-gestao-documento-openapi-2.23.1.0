          description: Indice de solititação da avaliação de autenticidade documental.
          type: boolean
        solicitacao_grafoscopia:
          description: Indice de solititação de grafoscopia documental.
          type: boolean
        solicitacao_validacao_externa:
          description: Indice de solititação de validação externa documental.
          type: boolean
        solicitacao_consulta_externa:
          description: Indice de solititação de consulta externa documental.
          type: boolean
        janela_extracao:
          description: Atributo janela temporal de extração.
          type: string
          allOf:
          - $ref: '#/components/schemas/JanelaTemporalExtracaoEnum'
        data_hora_retorno_classificacao:
          description: Data/Hora de captura do retorno da classificação.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_retorno_extracao:
          description: Data/Hora de captura do retorno da extração
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_retorno_validacao_negocial:
          description: Data/Hora do retorno da validação negocial
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_retorno_grafoscopia:
          description: Data/Hora do retorno da grafoscopia.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_retorno_avaliacao_autenticidade:
          description: Data/Hora de captura de envio do documento para o fornecedor.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_retorno_imagem_tratada:
          description: Data/Hora de retorno do resultado para execução do serviço
            de tratamento de imagem.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_hora_validacao_externa:
          description: Data/Hora de captura do retorno da classificação.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_consulta_externa:
          description: Data/Hora de captura do retorno da classificação.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        data_avaliacao_cadastral:
          description: Data/Hora de captura do retorno da avaliaçao cadastral.
          type: object
          allOf:
          - $ref: '#/components/schemas/Calendar'
          example: dd/MM/yyyy HH:mm:ss
        resultado_indice_avaliacao_autenticidade:
          description: ""
          type: number
        resultado_indice_grafoscopia:
          description: Resultado do serviço de avaliação de grafoscopia.
          type: number
        resultado_codigo_rejeicao:
          description: Código de identificação do problema apresentado no documento
            que impediu a execução do serviço.
          type: string
          allOf:
          - $ref: '#/components/schemas/CodigoRejeicaoEnum'
        resultado_descricao_rejeicao:
          description: Descrição do problema apresentado no documento que impediu
            a execução do serviço.
          type: string
        resultado_consulta_externa:
          description: ""
          type: string
        resultado_classificacao:
          description: ""
          type: string
        resultado_extracao:
          description: ""
          type: string
        resultado_validacao_negocial:
          description: ""
          type: string
